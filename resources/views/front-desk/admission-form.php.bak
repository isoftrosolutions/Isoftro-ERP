.callout-p::before { content: 'HIGH PRIORITY'; position: absolute; top: 1rem; left: 2rem; background: var(--p); color: #fff; font-size: 10px; font-weight: 900; padding: 4px 12px; border-radius: 50px; letter-spacing: 0.05em; }

